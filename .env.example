# Copy to .env and fill in — only the LIVE re-run needs these.
# The default reproduction (`uv run python -m tools.repro`) needs no key.
# Never commit your real .env (it is gitignored).

ANTHROPIC_API_KEY=      # triage agent + blind verifier (Anthropic) — required for a live core run
OPENAI_API_KEY=         # GPT-4o cross-provider ladder (OpenAI) — optional
REPLICATE_API_TOKEN=    # open-weight Llama-3-70B via Replicate — optional
