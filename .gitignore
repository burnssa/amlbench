# Internal commercial/strategy docs — NEVER commit (kept locally, out of the public repo)
internal/

# Secrets and local environment — NEVER commit
.env
.venv/
.phoenix/
.inspect/
__pycache__/
*.pyc
logs/
.DS_Store

# Signing private key — NEVER commit (the public key tools/keys/signing_public.hex IS committed)
tools/keys/signing_private.hex

# Data and results ARE committed (open by design): data/*.jsonl, results/runs/**, results/plots/*.png, docs/**

# BYO (customer-specific) run outputs + battery export — NEVER commit (regenerate locally)
results/byo/
results/runs/byo/

# Dry-run plumbing checks — not benchmark evidence (regenerate with run.py --mode dry)
results/runs/dry/

# Smoke-test deliverables (verify.sh / CI) — written via run.py --out-root results/smoke
# so plumbing checks can never overwrite the committed results/ artifacts
results/smoke/
results/BYO_REPORT.md
results/ledger/byo_*
results/finding/byo_*

# Agent reproduction output (produced on demand by tools.repro; force-add if you want it committed)
/results.json

# Exploratory framing-evaluation scratch (reproducible from eval.framing_eval; not committed —
# findings live in docs/AMLBENCH_FINDINGS.md). Force-add a specific dir if you want it kept.
results/framing_eval*/
results/adversary*/
# Canonical run: keep the authoritative leaderboard.json, drop the verbose stdout log.
results/canonical/run.log
results/canonical/decisions/
results/a3_panel/**/*.log

# Interp/probe experiment (interp/) — private holdout alerts + covers are a client-engagement
# asset, NEVER commit; activation tensors are bulk artifacts regenerated on the pod.
# Code (capture/, probes/, runpod/) and analysis outputs (interp/results/) ARE committed.
interp/data/
interp/activations/

# Per-case decision review exports — regenerable analysis scratch
results/review/

# stray / scratch from other tools — not part of the benchmark
.foo/
specs/
package-lock.json
.DS_Store
